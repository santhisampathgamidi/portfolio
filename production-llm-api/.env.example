# --- Provider selection ---
# Set to "ollama" for local Docker dev, "groq" for production.
LLM_BACKEND=ollama

# --- Groq (production) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Ollama (local) ---
OLLAMA_MODEL=llama3.2:1b

# --- Redis ---
# For local docker-compose this is set automatically.
# For production, paste your Upstash redis:// URL here.
REDIS_URL=

# --- Limits ---
RATE_LIMIT=10
CACHE_TTL=3600

# --- CORS ---
# Comma-separated list of allowed origins. No wildcards.
ALLOWED_ORIGINS=http://localhost:3000,https://your-portfolio.vercel.app
